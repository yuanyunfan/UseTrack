#!/usr/bin/env bash
set -euo pipefail

echo "🔍 Pre-commit checks..."

# 1. Swift build
echo "  [1/4] swift build..."
swift build 2>&1 || { echo "❌ Swift build failed"; exit 1; }

# 2. Swift test
echo "  [2/4] swift test..."
swift test 2>&1 || { echo "❌ Swift tests failed"; exit 1; }

# 3. Python lint (if python/ exists)
if [ -d python/ ] && [ -f python/pyproject.toml ]; then
    echo "  [3/4] ruff check..."
    (cd python && uv run ruff check .) || { echo "❌ Python lint failed"; exit 1; }

    # 4. Python test
    echo "  [4/4] pytest..."
    (cd python && uv run pytest tests/ -q) || { echo "❌ Python tests failed"; exit 1; }
else
    echo "  [3/4] Python not yet set up, skipping..."
    echo "  [4/4] Python not yet set up, skipping..."
fi

echo "✅ All checks passed"
