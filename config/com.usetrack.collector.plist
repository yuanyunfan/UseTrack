<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- LaunchAgent label (unique identifier) -->
    <key>Label</key>
    <string>com.usetrack.collector</string>

    <!-- Path to the collector binary -->
    <!-- install.sh substitutes __BINARY_DST__ → $HOME/bin/UseTrackCollector and -->
    <!-- __HOME__ → user home dir. User-local install: no sudo, no /usr/local/bin -->
    <key>ProgramArguments</key>
    <array>
        <string>__BINARY_DST__</string>
        <string>--db-path</string>
        <string>__HOME__/.usetrack/usetrack.db</string>
    </array>

    <!-- Start automatically at login -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Keep alive: restart if the process crashes -->
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <!-- Throttle restarts: wait 10 seconds between crash restarts -->
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <!-- Standard output and error logs -->
    <key>StandardOutPath</key>
    <string>/tmp/usetrack-collector.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/usetrack-collector.stderr.log</string>

    <!-- Process type: background (low priority, won't affect UI responsiveness) -->
    <key>ProcessType</key>
    <string>Background</string>

    <!-- Nice value: lower priority to minimize system impact -->
    <key>Nice</key>
    <integer>10</integer>
</dict>
</plist>
